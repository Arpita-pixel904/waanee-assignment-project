generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model users {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  password_hash String
  role          String   @default("AGENT")
  created_at    DateTime @default(now())
}

model leads {
  id          Int      @id @default(autoincrement())
  name        String
  email       String
  phone       String
  source      String
  status      String   @default("NEW")
  assigned_to Int?
  created_at  DateTime @default(now())
}
model activity_logs {
  id           Int      @id @default(autoincrement())
  lead_id      Int
  performed_by Int
  action_type  String
  details      String?
  created_at   DateTime @default(now())

  // Relationships (These help Prisma understand your FKs)
  lead         leads    @relation(fields: [lead_id], references: [id])
  user         users    @relation(fields: [performed_by], references: [id])
}